// SPDX-License-Identifier: MIT
pragma solidity ^0.8.18;

import "forge-std/Test.sol";
import "../src/ZybraGroup.sol";
import {IERC20} from "@openzeppelin/contracts/token/ERC20/IERC20.sol";
import {IERC4626} from "@openzeppelin/contracts/interfaces/IERC4626.sol";
import "../src/mocks/MockERC4626Vault.sol";
import "../src/mocks/MockERC20.sol";

/**
 * @title ZybraGroupWeeklyUpdated Test Suite
 * @notice Comprehensive tests for updated ROSCA model with:
 *   - Time-based automatic cycle progression
 *   - Strict time-window payout enforcement
 *   - Per-cycle contribution tracking
 *   - Auto-calculated yield from vault
 *   - 3% penalty for early withdrawal
 */
contract ZybraGroupWeeklyUpdatedTest is Test {
    ZybraGroup public group;
    MockERC20 public mockUSDC;
    MockERC4626Vault public mockVault;

    // Test addresses
    address public admin = address(0x1);
    address public member1 = address(0x2);
    address public member2 = address(0x3);
    address public member3 = address(0x4);

    // Test parameters
    uint256 public constant CONTRIBUTION_AMOUNT = 100e6; // 100 USDC
    uint256 public constant CYCLE_LENGTH = 4; // 4 cycles (number of members/cycles in cycle)
    uint256 public constant INITIAL_BALANCE = 10000e6; // 10,000 USDC per user

    event Contributed(address indexed member, uint256 amount, uint256 cycle);
    event RewardRedeemed(address indexed member, uint256 amount, uint256 cycle);
    event EmergencyWithdrawn(address indexed member, uint256 amount);
    event GroupStarted();

    function setUp() public {
        // Deploy mock USDC
        mockUSDC = new MockERC20("Mock USDC", "USDC", 6);

        // Deploy mock vault
        mockVault = new MockERC4626Vault(
            mockUSDC,
            "Mock Vault Token",
            "mvUSDC"
        );

        // Deploy ZybraGroup
        vm.startPrank(admin);
        group = new ZybraGroup(
            address(mockUSDC),
            CONTRIBUTION_AMOUNT,
            CYCLE_LENGTH,
            admin,
            address(mockVault),
            block.timestamp + 1 days // Start in 1 day
        );
        vm.stopPrank();

        // Mint USDC to test users
        mockUSDC.mint(admin, INITIAL_BALANCE);
        mockUSDC.mint(member1, INITIAL_BALANCE);
        mockUSDC.mint(member2, INITIAL_BALANCE);
        mockUSDC.mint(member3, INITIAL_BALANCE);

        // Approve group contract
        vm.prank(admin);
        mockUSDC.approve(address(group), type(uint256).max);
        vm.prank(member1);
        mockUSDC.approve(address(group), type(uint256).max);
        vm.prank(member2);
        mockUSDC.approve(address(group), type(uint256).max);
        vm.prank(member3);
        mockUSDC.approve(address(group), type(uint256).max);
    }

    // ==================== HELPER FUNCTIONS ====================

    function mintUSDC(address to, uint256 amount) internal {
        mockUSDC.mint(to, amount);
    }

    function approveUSDC(address owner, address spender, uint256 amount) internal {
        vm.prank(owner);
        mockUSDC.approve(spender, amount);
    }

    // ==================== TEST: GROUP SETUP ====================

    function test_GroupCreation() public {
        assertEq(group.admin(), admin);
        assertEq(address(group.asset()), address(mockUSDC));
        assertEq(group.contributionAmount(), CONTRIBUTION_AMOUNT);
        assertEq(group.totalCycles(), CYCLE_LENGTH);
        assertFalse(group.poolStarted());
        assertFalse(group.poolEnded());
    }

    function test_JoinGroup() public {
        vm.startPrank(admin);
        group.joinGroup(member1);
        group.joinGroup(member2);
        group.joinGroup(member3);
        vm.stopPrank();

        assertTrue(group.isMember(member1));
        assertTrue(group.isMember(member2));
        assertTrue(group.isMember(member3));
        assertEq(group.membersCount(), 4); // admin + 3 members
    }

    function test_CannotJoinAfterGroupStarts() public {
        // Join members
        vm.startPrank(admin);
        group.joinGroup(member1);
        group.joinGroup(member2);

        // Advance time and start pool
        vm.warp(block.timestamp + 1 days);
        group.startGroup();

        // Try to join after pool started
        vm.expectRevert(ZybraGroup.GroupAlreadyStarted.selector);
        group.joinGroup(member3);
        vm.stopPrank();
    }

    // ==================== TEST: TIME-BASED CYCLE PROGRESSION ====================

    function test_GetCurrentCycle_BeforeGroupStarts() public {
        assertEq(group.getCurrentCycle(), 0);
    }

    function test_GetCurrentCycle_AfterGroupStarts() public {
        // Join members and start pool
        vm.startPrank(admin);
        group.joinGroup(member1);
        group.joinGroup(member2);
        vm.warp(block.timestamp + 1 days);
        group.startGroup();
        vm.stopPrank();

        // Cycle 1: 0-7 days after pool start
        assertEq(group.getCurrentCycle(), 1);

        // Cycle 2: 7-14 days after pool start
        vm.warp(block.timestamp + 7 days);
        assertEq(group.getCurrentCycle(), 2);

        // Cycle 3: 14-21 days after pool start
        vm.warp(block.timestamp + 7 days);
        assertEq(group.getCurrentCycle(), 3);
    }

    // NOTE: isWithinCycleWindow() function has been removed from contract
    // function test_IsWithinCycleWindow() public {
    //     vm.startPrank(admin);
    //     group.joinGroup(member1);
    //     group.joinGroup(member2);
    //     vm.warp(block.timestamp + 1 days);
    //     uint256 poolStart = block.timestamp;
    //     group.startGroup();
    //     vm.stopPrank();

    //     // During cycle 1
    //     assertTrue(group.isWithinCycleWindow(1));
    //     assertFalse(group.isWithinCycleWindow(2));

    //     // Move to cycle 2
    //     vm.warp(poolStart + 7 days);
    //     assertFalse(group.isWithinCycleWindow(1));
    //     assertTrue(group.isWithinCycleWindow(2));

    //     // Move to cycle 3
    //     vm.warp(poolStart + 14 days);
    //     assertFalse(group.isWithinCycleWindow(2));
    //     assertTrue(group.isWithinCycleWindow(3));
    // }

    // ==================== TEST: CONTRIBUTIONS ====================

    function test_Contribute_PerCycleTracking() public {
        // Setup pool
        vm.startPrank(admin);
        group.joinGroup(member1);
        vm.warp(block.timestamp + 1 days);
        group.startGroup();
        vm.stopPrank();

        // Member1 contributes in cycle 1
        vm.prank(member1);
        group.contribute();

        assertEq(group.getMemberContributionForCycle(member1, 1), CONTRIBUTION_AMOUNT);
        assertTrue(group.hasContributedThisCycle(member1));

        // Move to cycle 2
        vm.warp(block.timestamp + 7 days);

        // Cycle 2 contribution should be separate
        assertEq(group.getMemberContributionForCycle(member1, 2), 0);
        assertFalse(group.hasContributedThisCycle(member1));

        // Contribute in cycle 2
        vm.prank(member1);
        group.contribute();

        assertEq(group.getMemberContributionForCycle(member1, 2), CONTRIBUTION_AMOUNT);
        assertTrue(group.hasContributedThisCycle(member1));
    }

    function test_Contribute_InsufficientBalance() public {
        vm.startPrank(admin);
        group.joinGroup(member1);
        vm.warp(block.timestamp + 1 days);
        group.startGroup();
        vm.stopPrank();

        // Create a member with insufficient balance
        address poorMember = address(0x999);
        vm.prank(admin);
        group.joinGroup(poorMember);

        // Give only partial amount
        mintUSDC(poorMember, CONTRIBUTION_AMOUNT / 2);
        approveUSDC(poorMember, address(group), type(uint256).max);

        vm.prank(poorMember);
        vm.expectRevert(); // SafeERC20 will revert on insufficient balance
        group.contribute();
    }

    // ==================== TEST: PAYOUT LOGIC ====================

    function test_RedeemReward_Success() public {
        // Setup: 2 members
        vm.startPrank(admin);
        group.joinGroup(member1);
        group.joinGroup(member2);
        vm.warp(block.timestamp + 1 days);
        group.startGroup();
        vm.stopPrank();

        // Simulate vault yield generation by depositing extra tokens
        // This increases the assets-to-shares ratio
        mockUSDC.mint(address(mockVault), 1000e6);

        // Member1 (cycle 1) contributes
        vm.prank(member1);
        group.contribute();

        // Member1 claims during cycle 1
        bytes32[] memory emptyProof = new bytes32[](0);
        vm.prank(member1);
        uint256 expectedPayout = group.getExpectedPayoutAmount();
        vm.expectEmit(true, true, true, false); // Don't check payout amount
        emit RewardRedeemed(member1, expectedPayout, 1);
        group.redeemReward(emptyProof);

        // Verify member1 claimed
        (uint256 totalContributed, bool hasClaimed, uint256 joinedAt) = group.getMemberInfo(member1);
        assertTrue(hasClaimed);
    }

    function test_RedeemReward_MustContributeFirst() public {
        vm.startPrank(admin);
        group.joinGroup(member1);
        vm.warp(block.timestamp + 1 days);
        group.startGroup();
        vm.stopPrank();

        // Try to claim without contributing
        bytes32[] memory emptyProof = new bytes32[](0);
        vm.prank(member1);
        vm.expectRevert(ZybraGroup.InvalidAmount.selector);
        group.redeemReward(emptyProof);
    }

    function test_RedeemReward_StrictTimeWindow() public {
        // Setup: member1 = cycle 1, member2 = cycle 2
        vm.startPrank(admin);
        group.joinGroup(member1);
        group.joinGroup(member2);
        vm.warp(block.timestamp + 1 days);
        uint256 poolStart = block.timestamp;
        group.startGroup();
        vm.stopPrank();

        // Member1 contributes in cycle 1
        vm.prank(member1);
        group.contribute();

        // Move to cycle 2 (member1's window expired)
        vm.warp(poolStart + 7 days);

        // Member1 tries to claim in cycle 2 - SHOULD FAIL (wrong cycle)
        bytes32[] memory emptyProof = new bytes32[](0);
        vm.prank(member1);
        vm.expectRevert(ZybraGroup.InvalidProof.selector);
        group.redeemReward(emptyProof);
    }

    function test_RedeemReward_CannotClaimTwice() public {
        vm.startPrank(admin);
        group.joinGroup(member1);
        vm.warp(block.timestamp + 1 days);
        group.startGroup();
        vm.stopPrank();

        // Simulate vault yield by minting tokens to the vault
        mockUSDC.mint(address(mockVault), 500e6);

        // Contribute and claim
        vm.startPrank(member1);
        group.contribute();
        bytes32[] memory emptyProof = new bytes32[](0);
        group.redeemReward(emptyProof);

        // Try to claim again
        vm.expectRevert(ZybraGroup.AlreadyClaimed.selector);
        group.redeemReward(emptyProof);
        vm.stopPrank();
    }

    // ==================== TEST: EMERGENCY WITHDRAW ====================

    function test_EmergencyWithdraw_EarlyExit_3PercentPenalty() public {
        vm.startPrank(admin);
        group.joinGroup(member1);
        vm.warp(block.timestamp + 1 days);
        group.startGroup();
        vm.stopPrank();

        // Member1 contributes
        vm.prank(member1);
        group.contribute();

        uint256 balanceBefore = mockUSDC.balanceOf(member1);

        // Early withdrawal (pool not ended)
        vm.prank(member1);
        group.emergencyWithdraw();

        uint256 balanceAfter = mockUSDC.balanceOf(member1);
        uint256 received = balanceAfter - balanceBefore;

        // Should receive 97% (3% penalty)
        uint256 expected = CONTRIBUTION_AMOUNT * 97 / 100;
        assertEq(received, expected);
    }

    function test_EmergencyWithdraw_AfterGroupEnds_NoPenalty() public {
        vm.startPrank(admin);
        group.joinGroup(member1);
        vm.warp(block.timestamp + 1 days);
        group.startGroup();
        vm.stopPrank();

        // Member1 contributes
        vm.prank(member1);
        group.contribute();

        // Admin ends pool
        vm.prank(admin);
        group.endGroup();

        uint256 balanceBefore = mockUSDC.balanceOf(member1);

        // Withdrawal after pool ended (no penalty)
        vm.prank(member1);
        group.emergencyWithdraw();

        uint256 balanceAfter = mockUSDC.balanceOf(member1);
        uint256 received = balanceAfter - balanceBefore;

        // Should receive 100% (no penalty)
        assertEq(received, CONTRIBUTION_AMOUNT);
    }

    // ==================== TEST: VIEW FUNCTIONS ====================

    function test_CanMemberClaim() public {
        vm.startPrank(admin);
        group.joinGroup(member1);
        vm.warp(block.timestamp + 1 days);
        group.startGroup();
        vm.stopPrank();

        // Before contribution - need to pass payoutCycle parameter
        (bool canClaim, string memory reason) = group.canMemberClaim(member1, 2);
        assertFalse(canClaim);
        assertEq(reason, "Not within payout time window"); // Cycle 1, not cycle 2

        // Advance to cycle 2
        vm.warp(block.timestamp + 7 days);

        // Still can't claim without contribution
        (canClaim, reason) = group.canMemberClaim(member1, 2);
        assertFalse(canClaim);
        assertEq(reason, "Must contribute first");

        // After contribution
        vm.prank(member1);
        group.contribute();

        // Simulate vault yield
        mockUSDC.mint(address(mockVault), 200e6);

        (canClaim, reason) = group.canMemberClaim(member1, 2);
        assertTrue(canClaim);
        assertEq(reason, "Can claim");
    }

    function test_GetGroupStatus() public {
        vm.startPrank(admin);
        group.joinGroup(member1);
        group.joinGroup(member2);
        vm.warp(block.timestamp + 1 days);
        group.startGroup();
        vm.stopPrank();

        (
            bool started,
            bool ended,
            uint256 currentCycle,
            uint256 totalMembers,
            uint256 activeMembers,
            ,

        ) = group.getGroupStatus();

        assertTrue(started);
        assertFalse(ended);
        assertEq(currentCycle, 1);
        assertEq(totalMembers, 3); // admin + 2 members
        assertEq(activeMembers, 3);
    }
}
